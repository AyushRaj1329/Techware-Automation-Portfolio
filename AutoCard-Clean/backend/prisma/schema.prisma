// Prisma schema for AutoCard Systems
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================================================================
// ENUMS
// ===========================================================================

enum Role {
  ADMIN
  EMPLOYEE
  CUSTOMER
}

enum OnboardingStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  ON_LEAVE
  HOLIDAY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum RequestType {
  ONBOARDING
  GENERAL
  DOCUMENT
  EQUIPMENT
  CORRECTION
  OTHER
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProjectStatus {
  PLANNED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

// ===========================================================================
// AUTH & PROFILES
// ===========================================================================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  role         Role     @default(CUSTOMER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // One-to-one role profiles.
  employeeProfile EmployeeProfile?
  customerProfile CustomerProfile?

  // Admin review activity.
  reviewedLeaveRequests LeaveRequest[]    @relation("LeaveReviewer")
  reviewedRequests      EmployeeRequest[] @relation("RequestReviewer")

  @@index([role])
  @@map("users")
}

model EmployeeProfile {
  id           String           @id @default(uuid())
  userId       String           @unique
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeCode String           @unique
  onboardingStatus OnboardingStatus @default(PENDING)

  // --- Personal details ---
  firstName       String?
  lastName        String?
  phone           String?
  alternatePhone  String?
  personalEmail   String?
  dateOfBirth     DateTime?
  gender          String?
  maritalStatus   String?
  nationality     String?
  bloodGroup      String?

  // Current + permanent address.
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  postalCode      String?
  country         String?

  // --- Emergency contact ---
  emergencyContactName     String?
  emergencyContactRelation String?
  emergencyContactPhone    String?

  // --- Banking details ---
  bankName          String?
  bankAccountName   String?
  bankAccountNumber String?
  bankIfscCode      String?
  bankBranch        String?

  // --- Professional details ---
  jobTitle          String?
  highestQualification String?
  university           String?
  graduationYear       Int?
  totalExperienceYears Float?
  previousemployer     String?
  skills               String?

  // --- Identification / proofs ---
  nationalIdNumber  String?
  taxIdNumber       String?
  passportNumber    String?
  // Uploaded document references (file names / URLs).
  idProofDocument        String?
  addressProofDocument   String?
  educationProofDocument String?
  resumeDocument         String?

  // --- Job assignment (admin-managed) ---
  departmentId     String?
  department       Department?      @relation(fields: [departmentId], references: [id])
  dateOfJoining    DateTime?

  // Default shift & location assignment.
  shiftId    String?
  shift      Shift?    @relation(fields: [shiftId], references: [id])
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])

  // Reporting manager (self relation).
  managerId String?
  manager   EmployeeProfile?  @relation("EmployeeManager", fields: [managerId], references: [id])
  reports   EmployeeProfile[] @relation("EmployeeManager")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations.
  attendances        Attendance[]
  leaveRequests      LeaveRequest[]
  leaveBalances      LeaveBalance[]
  requests           EmployeeRequest[]
  rosterEntries      RosterEntry[]
  projectAssignments ProjectAssignment[]

  @@index([departmentId])
  @@map("employee_profiles")
}

model CustomerProfile {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName String?
  phone       String?
  address     String?
  city        String?
  country     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // A customer owns many projects.
  projects Project[]

  @@map("customer_profiles")
}

// ===========================================================================
// ORG STRUCTURE: DEPARTMENT, SHIFT, LOCATION
// ===========================================================================

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees EmployeeProfile[]

  @@map("departments")
}

model Shift {
  id          String   @id @default(uuid())
  name        String   @unique
  startTime   String // "HH:mm" 24-hour format
  endTime     String // "HH:mm" 24-hour format
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees     EmployeeProfile[]
  rosterEntries RosterEntry[]

  @@map("shifts")
}

model Location {
  id          String   @id @default(uuid())
  name        String   @unique
  addressLine String?
  city        String?
  state       String?
  country     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees     EmployeeProfile[]
  rosterEntries RosterEntry[]

  @@map("locations")
}

// ===========================================================================
// ROSTER
// ===========================================================================

model RosterEntry {
  id         String   @id @default(uuid())
  employeeId String
  employee   EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date       DateTime @db.Date
  shiftId    String
  shift      Shift    @relation(fields: [shiftId], references: [id])
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])
  note       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([employeeId, date])
  @@index([date])
  @@map("roster_entries")
}

// ===========================================================================
// ATTENDANCE
// ===========================================================================

model Attendance {
  id          String           @id @default(uuid())
  employeeId  String
  employee    EmployeeProfile  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  date        DateTime         @db.Date
  checkIn     DateTime?
  checkOut    DateTime?
  status      AttendanceStatus @default(PRESENT)
  workedHours Float?
  note        String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([employeeId, date])
  @@index([date])
  @@map("attendance")
}

// ===========================================================================
// LEAVE: POLICY (TYPES + BALANCES) AND REQUESTS
// ===========================================================================

model LeaveType {
  id          String   @id @default(uuid())
  name        String   @unique
  code        String   @unique
  daysPerYear Int      @default(0)
  description String?
  isPaid      Boolean  @default(true)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  balances LeaveBalance[]
  requests LeaveRequest[]

  @@map("leave_types")
}

model LeaveBalance {
  id          String          @id @default(uuid())
  employeeId  String
  employee    EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId String
  leaveType   LeaveType       @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  year        Int
  allocated   Float           @default(0)
  used        Float           @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@unique([employeeId, leaveTypeId, year])
  @@map("leave_balances")
}

model LeaveRequest {
  id          String          @id @default(uuid())
  employeeId  String
  employee    EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveTypeId String
  leaveType   LeaveType       @relation(fields: [leaveTypeId], references: [id])
  startDate   DateTime        @db.Date
  endDate     DateTime        @db.Date
  totalDays   Float
  reason      String?
  status      LeaveStatus     @default(PENDING)

  // Admin review.
  reviewedById String?
  reviewedBy   User?     @relation("LeaveReviewer", fields: [reviewedById], references: [id])
  reviewNote   String?
  reviewedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([status])
  @@map("leave_requests")
}

// ===========================================================================
// HOLIDAYS
// ===========================================================================

model Holiday {
  id          String   @id @default(uuid())
  name        String
  date        DateTime @unique @db.Date
  description String?
  isRecurring Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("holidays")
}

// ===========================================================================
// REQUESTS (ADMIN INBOX FOR NON-LEAVE EMPLOYEE REQUESTS)
// ===========================================================================

model EmployeeRequest {
  id          String          @id @default(uuid())
  employeeId  String
  employee    EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  type        RequestType     @default(GENERAL)
  subject     String
  description String?
  status      RequestStatus   @default(PENDING)

  // Admin review.
  reviewedById String?
  reviewedBy   User?     @relation("RequestReviewer", fields: [reviewedById], references: [id])
  reviewNote   String?
  reviewedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([status])
  @@map("employee_requests")
}

// ===========================================================================
// PROJECTS
// ===========================================================================

model Project {
  id          String        @id @default(uuid())
  name        String
  code        String        @unique
  description String?
  status      ProjectStatus @default(PLANNED)
  startDate   DateTime?     @db.Date
  endDate     DateTime?     @db.Date

  // Owning customer (optional — internal projects may have none).
  customerId String?
  customer   CustomerProfile? @relation(fields: [customerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments ProjectAssignment[]

  @@index([customerId])
  @@index([status])
  @@map("projects")
}

model ProjectAssignment {
  id            String          @id @default(uuid())
  projectId     String
  project       Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employeeId    String
  employee      EmployeeProfile @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  roleOnProject String?
  assignedAt    DateTime        @default(now())

  @@unique([projectId, employeeId])
  @@map("project_assignments")
}

// ===========================================================================
// ROLES & ACCESS (PER-ROLE, PER-MODULE PERMISSIONS)
// ===========================================================================

model AccessControl {
  id        String   @id @default(uuid())
  role      Role
  moduleKey String // matches the frontend module key, e.g. "attendance"
  canView   Boolean  @default(false)
  canCreate Boolean  @default(false)
  canEdit   Boolean  @default(false)
  canDelete Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([role, moduleKey])
  @@map("access_controls")
}

// ===========================================================================
// MISC (EXISTING)
// ===========================================================================

model ContactSubmission {
  id        String   @id @default(uuid())
  name      String
  email     String
  company   String?
  message   String
  createdAt DateTime @default(now())

  @@map("contact_submissions")
}
