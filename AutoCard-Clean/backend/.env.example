# Server
PORT=4000

# CORS - your deployed frontend URL
CLIENT_ORIGIN=https://your-frontend-domain.com

# Gmail SMTP credentials (use an App Password, not your account password)
# EMAIL_USER is the account used to SEND the email
EMAIL_USER=your-sending-email@gmail.com
EMAIL_PASS=your-app-password

# EMAIL_TO is the address that RECEIVES the contact form submissions
# If not set, falls back to EMAIL_USER
EMAIL_TO=your-receiving-email@gmail.com
